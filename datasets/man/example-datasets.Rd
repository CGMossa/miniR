\name{example-datasets}
\alias{example-datasets}
\title{miniR Example Dataset Bundle}
\description{
A small bundle of freely redistributable teaching datasets for miniR examples.
}
\details{
This bundle intentionally excludes GPL-tied R package mirrors and datasets with
ambiguous redistribution terms. The current set contains six datasets:
\code{iris}, \code{wine}, \code{auto_mpg}, \code{abalone},
\code{breast_cancer_wisconsin_diagnostic}, and \code{penguins}.

Five come from the UCI Machine Learning Repository under CC BY 4.0. The
Palmer penguins data is provided under CC0 1.0.
}
\source{
See \file{datasets/manifest.tsv} for source URLs, local filenames, and license
information.
}
\keyword{datasets}
