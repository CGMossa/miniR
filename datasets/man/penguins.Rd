\name{penguins}
\alias{penguins}
\title{Palmer Penguins}
\description{
A 344-row penguin measurement dataset designed for data exploration and
visualization, widely used in teaching as a modern alternative to \code{iris}.
}
\format{
A CSV file with 344 rows and 8 columns:
\describe{
  \item{species}{Penguin species.}
  \item{island}{Island of observation.}
  \item{bill_length_mm}{Bill length in millimeters.}
  \item{bill_depth_mm}{Bill depth in millimeters.}
  \item{flipper_length_mm}{Flipper length in millimeters.}
  \item{body_mass_g}{Body mass in grams.}
  \item{sex}{Sex, with missing values in some rows.}
  \item{year}{Observation year.}
}
}
\details{
Local file: \file{datasets/data/penguins.csv}. This is the simplified CSV
published by the official palmerpenguins project.
}
\source{
palmerpenguins project page:
\url{https://allisonhorst.github.io/palmerpenguins/}.
Original CSV:
\url{https://raw.githubusercontent.com/allisonhorst/palmerpenguins/master/inst/extdata/penguins.csv}.
License: CC0 1.0.
}
\references{
Horst, A. M., Hill, A. P., and Gorman, K. B. (2020). palmerpenguins: Palmer
Archipelago (Antarctica) penguin data.
\url{https://doi.org/10.5281/zenodo.3960218}.
Original study: Gorman, K. B., Williams, T. D., and Fraser, W. R. (2014).
\url{https://doi.org/10.1371/journal.pone.0090081}.
}
\keyword{datasets}
